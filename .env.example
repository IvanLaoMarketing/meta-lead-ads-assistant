# ============================================================
# META Lead ADS Assistant — by Ivan Lao (laoivan.com)
# Copia questo file in .env e compila con i tuoi valori reali
# NON committare mai il file .env su Git
# ============================================================

# --- META / FACEBOOK ---
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id_here
META_PAGE_ID=your_facebook_page_id_here
META_INSTAGRAM_ACTOR_ID=your_instagram_actor_id_here
META_PIXEL_ID=your_meta_pixel_id_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# --- LLM (OpenRouter — GPT-4 consigliato) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4

# --- NOTIFICHE TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- MAKE.COM (Webhook Automazioni Esterne) ---
MAKE_WEBHOOK_CAMPAGNA_CREATA=https://hook.eu1.make.com/your_webhook_id
MAKE_WEBHOOK_ALERT_KPI=https://hook.eu1.make.com/your_webhook_kpi_id

# --- N8N (Webhook Automazioni Esterne) ---
N8N_WEBHOOK_CAMPAGNA_CREATA=https://your-n8n-instance.com/webhook/campagna-creata
N8N_WEBHOOK_ALERT_KPI=https://your-n8n-instance.com/webhook/alert-kpi

# --- GOOGLE SHEETS (CRM / Storico Campagne e KPI) ---
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# --- IMPOSTAZIONI GENERALI ---
LOG_LEVEL=INFO
OUTPUT_DIR=data/output
LOGS_DIR=data/logs

# --- CANALE NOTIFICA PREFERITO (telegram | make | n8n | nessuno) ---
NOTIFICATION_CHANNEL=telegram
