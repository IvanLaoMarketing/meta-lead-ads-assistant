# ============================================================
# META Lead ADS Assistant — Variabili d'Ambiente
# Copia questo file in .env e compila con i tuoi valori reali
# NON committare mai il file .env su Git
# ============================================================

# --- META / FACEBOOK ---
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id_here
META_PAGE_ID=your_facebook_page_id_here
META_PIXEL_ID=your_meta_pixel_id_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# --- OPENROUTER (LLM: GPT-4) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4

# --- NOTIFICHE TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- WHATSAPP BUSINESS (Meta Cloud API) ---
# Usato per notifiche avanzate e report KPI via WhatsApp
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_RECIPIENT_NUMBER=your_whatsapp_number_here   # es. 393331234567

# --- BASEROW (CRM / Storico Campagne) ---
# Usato per salvare campagne create, KPI e lead generati
BASEROW_API_URL=https://api.baserow.io
BASEROW_TOKEN=your_baserow_token_here
BASEROW_TABLE_CAMPAGNE=your_table_id_campagne
BASEROW_TABLE_KPI=your_table_id_kpi

# --- MAKE.COM (Webhook Automazioni Esterne) ---
# Webhook Make da chiamare dopo creazione campagna o alert KPI
MAKE_WEBHOOK_CAMPAGNA_CREATA=https://hook.eu1.make.com/your_webhook_id
MAKE_WEBHOOK_ALERT_KPI=https://hook.eu1.make.com/your_webhook_kpi_id

# --- N8N (Webhook Automazioni Esterne) ---
# Alternativa a Make per automazioni esterne
N8N_WEBHOOK_CAMPAGNA_CREATA=https://your-n8n-instance.com/webhook/campagna-creata
N8N_WEBHOOK_ALERT_KPI=https://your-n8n-instance.com/webhook/alert-kpi

# --- IMPOSTAZIONI GENERALI ---
LOG_LEVEL=INFO
OUTPUT_DIR=data/output
LOGS_DIR=data/logs

# --- NOTIFICA PREFERITA (telegram | whatsapp | make | n8n | tutti) ---
NOTIFICATION_CHANNEL=telegram
